{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "common": {
      "properties": {
        "metadata": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "configMap": {
      "properties": {
        "metadata": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "container": {
      "properties": {
        "spec": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "deployment": {
      "properties": {
        "metadata": {
          "type": "object"
        },
        "spec": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "lotus": {
      "properties": {
        "apis": {
          "properties": {
            "icanhazdadjoke": {
              "properties": {
                "host": {
                  "type": "string"
                },
                "path": {
                  "type": ["null", "string"]
                },
                "port": {
                  "type": ["integer", "null"]
                },
                "scheme": {
                  "type": "string"
                }
              },
              "required": ["scheme", "host"],
              "type": "object"
            },
            "pelican": {
              "properties": {
                "host": {
                  "type": "string"
                },
                "path": {
                  "type": ["null", "string"]
                },
                "port": {
                  "type": ["integer", "null"]
                },
                "scheme": {
                  "type": "string"
                }
              },
              "required": ["scheme", "host"],
              "type": "object"
            }
          },
          "required": ["icanhazdadjoke", "pelican"],
          "type": "object"
        },
        "debug": {
          "type": "boolean"
        },
        "server": {
          "properties": {
            "port": {
              "type": "integer"
            }
          },
          "required": ["port"],
          "type": "object"
        }
      },
      "required": ["apis", "debug", "server"],
      "type": "object"
    },
    "name": {
      "type": "string"
    },
    "pod": {
      "properties": {
        "metadata": {
          "type": "object"
        },
        "spec": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "service": {
      "properties": {
        "metadata": {
          "type": "object"
        },
        "port": {
          "type": "integer"
        },
        "spec": {
          "type": "object"
        }
      },
      "required": ["port"],
      "type": "object"
    }
  },
  "required": ["lotus", "service"],
  "type": "object"
}
