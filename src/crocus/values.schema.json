{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "common": {
      "properties": {
        "metadata": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "configMap": {
      "properties": {
        "metadata": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "container": {
      "properties": {
        "spec": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "crocus": {
      "properties": {
        "apis": {
          "properties": {
            "icanhazdadjoke": {
              "properties": {
                "host": {
                  "type": "string"
                },
                "path": {
                  "type": ["null", "string"]
                },
                "port": {
                  "type": ["integer", "null"]
                },
                "scheme": {
                  "type": "string"
                }
              },
              "required": ["scheme", "host"],
              "type": "object"
            },
            "scorpion": {
              "properties": {
                "host": {
                  "type": "string"
                },
                "path": {
                  "type": ["null", "string"]
                },
                "port": {
                  "type": ["integer", "null"]
                },
                "scheme": {
                  "type": "string"
                }
              },
              "required": ["scheme", "host"],
              "type": "object"
            }
          },
          "required": ["icanhazdadjoke", "scorpion"],
          "type": "object"
        },
        "debug": {
          "type": "boolean"
        },
        "secrets": {
          "properties": {
            "shared": {
              "maxLength": 32,
              "minLength": 32,
              "type": "string"
            }
          },
          "required": ["shared"],
          "type": "object"
        },
        "server": {
          "properties": {
            "port": {
              "type": "integer"
            }
          },
          "required": ["port"],
          "type": "object"
        },
        "urls": {
          "properties": {
            "orchid": {
              "properties": {
                "host": {
                  "type": "string"
                },
                "path": {
                  "type": ["null", "string"]
                },
                "port": {
                  "type": ["integer", "null"]
                },
                "scheme": {
                  "type": "string"
                }
              },
              "required": ["scheme", "host"],
              "type": "object"
            }
          },
          "required": ["orchid"],
          "type": "object"
        }
      },
      "required": ["apis", "debug", "secrets", "server", "urls"],
      "type": "object"
    },
    "deployment": {
      "properties": {
        "metadata": {
          "type": "object"
        },
        "spec": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "name": {
      "type": "string"
    },
    "pod": {
      "properties": {
        "metadata": {
          "type": "object"
        },
        "spec": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "secret": {
      "properties": {
        "metadata": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "service": {
      "properties": {
        "metadata": {
          "type": "object"
        },
        "port": {
          "type": "integer"
        },
        "spec": {
          "type": "object"
        }
      },
      "required": ["port"],
      "type": "object"
    }
  },
  "required": ["crocus", "service"],
  "type": "object"
}
