{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "common": {
      "properties": {
        "metadata": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "configMap": {
      "properties": {
        "metadata": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "container": {
      "properties": {
        "spec": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "deployment": {
      "properties": {
        "metadata": {
          "type": "object"
        },
        "spec": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "name": {
      "type": "string"
    },
    "pod": {
      "properties": {
        "metadata": {
          "type": "object"
        },
        "spec": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "scorpion": {
      "properties": {
        "clients": {
          "additionalProperties": {
            "additionalProperties": true,
            "type": "object"
          },
          "type": "object"
        },
        "crocus": {
          "properties": {
            "public": {
              "properties": {
                "host": {
                  "type": "string"
                },
                "path": {
                  "type": ["null", "string"]
                },
                "port": {
                  "type": ["integer", "null"]
                },
                "scheme": {
                  "type": "string"
                }
              },
              "required": ["host", "scheme"],
              "type": "object"
            }
          },
          "required": ["public"],
          "type": "object"
        },
        "debug": {
          "type": "boolean"
        },
        "diamond": {
          "properties": {
            "sql": {
              "properties": {
                "host": {
                  "type": "string"
                },
                "password": {
                  "type": "string"
                },
                "port": {
                  "type": "integer"
                }
              },
              "required": ["host", "password", "port"],
              "type": "object"
            }
          },
          "required": ["sql"],
          "type": "object"
        },
        "janitor": {
          "properties": {
            "retention": {
              "type": "string"
            }
          },
          "required": ["retention"],
          "type": "object"
        },
        "lifetimes": {
          "properties": {
            "tokens": {
              "properties": {
                "access": {
                  "type": "string"
                },
                "refresh": {
                  "type": "string"
                }
              },
              "required": ["access", "refresh"],
              "type": "object"
            }
          },
          "required": ["tokens"],
          "type": "object"
        },
        "secrets": {
          "properties": {
            "cookie": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "system": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          "required": ["cookie", "system"],
          "type": "object"
        },
        "server": {
          "properties": {
            "ports": {
              "properties": {
                "admin": {
                  "type": "integer"
                },
                "public": {
                  "type": "integer"
                }
              },
              "required": ["admin", "public"],
              "type": "object"
            }
          },
          "required": ["ports"],
          "type": "object"
        },
        "urls": {
          "properties": {
            "admin": {
              "type": "string"
            },
            "issuer": {
              "type": "string"
            },
            "public": {
              "type": "string"
            }
          },
          "required": ["admin", "issuer", "public"],
          "type": "object"
        }
      },
      "required": [
        "clients",
        "crocus",
        "debug",
        "diamond",
        "janitor",
        "lifetimes",
        "secrets",
        "server",
        "urls"
      ],
      "type": "object"
    },
    "secret": {
      "properties": {
        "metadata": {
          "type": "object"
        }
      },
      "type": "object"
    },
    "service": {
      "properties": {
        "metadata": {
          "type": "object"
        },
        "ports": {
          "properties": {
            "admin": {
              "type": "integer"
            },
            "public": {
              "type": "integer"
            }
          },
          "required": ["admin", "public"],
          "type": "object"
        },
        "spec": {
          "type": "object"
        }
      },
      "required": ["ports"],
      "type": "object"
    }
  },
  "required": ["scorpion", "service"],
  "type": "object"
}
